# Frontend API URLs.
# LOCAL active with API Gateway:
VITE_API_GATEWAY_URL=http://localhost:8080
# EC2 ready with DuckDNS and API Gateway:
# VITE_API_GATEWAY_URL=http://roomiegram.duckdns.org:8080

# Direct microservice fallback. Used only when VITE_API_GATEWAY_URL is empty.
# LOCAL fallback:
VITE_API_BASE_URL=http://localhost
# EC2 fallback:
# VITE_API_BASE_URL=http://roomiegram.duckdns.org

# Backend CORS patterns accepted by Spring services.
# LOCAL active:
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://*:5173
# EC2 ready:
# APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://roomiegram.duckdns.org,http://roomiegram.duckdns.org:*,http://localhost:*,http://127.0.0.1:*,http://*:5173

# Frontend URL used in email links.
# LOCAL active:
APP_FRONTEND_URL=http://localhost:5173
# EC2 ready:
# APP_FRONTEND_URL=http://roomiegram.duckdns.org

# Frontend published port. Use 5173 locally and 80 on EC2 to open http://roomiegram.duckdns.org without a port.
FRONTEND_PORT=5173
# FRONTEND_PORT=80

# Mercado Pago settings.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_URL=

# Local-only demo mode for portfolio testing.
PAGOS_DEMO_ENABLED=false

# Shared database credentials used by docker-compose.
MYSQL_ROOT_PASSWORD=roomiegram
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=roomiegram

# Internal service URLs used between containers.
HOGAR_SERVICE_URL=http://hogar:8083

# Mail settings for password recovery.
# Leave empty locally if you do not want to send real recovery emails.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=no-reply@roomiegram.com
